{
  "expo": {
    "name": "Kover",
    "slug": "kover",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#02100C"
    },
    "scheme": "kover",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kover.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Kover uses your front camera during SOS mode so you can see yourself and stay grounded.",
        "NSMicrophoneUsageDescription": "Kover uses your microphone for voice journal entries.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ]
      },
      "entitlements": {
        "com.apple.developer.networking.networkextension": [
          "dns-settings"
        ],
        "aps-environment": "production"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#02100C"
      },
      "package": "com.kover.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_DATA_SYNC",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.BIND_VPN_SERVICE",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-notifications",
      "expo-secure-store",
      "expo-image-picker",
      "expo-font",
      "./withKoverVpnService"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "263502e1-47e9-41af-9124-cee2b466cb58"
      }
    },
    "owner": "koverwellness"
  }
}
